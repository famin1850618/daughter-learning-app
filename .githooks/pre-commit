#!/usr/bin/env bash
# V3.19.2 pre-commit hook: 防 group_id 跨 batch 命名空间冲突
# 启用方式（新设备 clone 后跑一次）: git config core.hooksPath .githooks
#
# 触发条件：本次 commit 改动了 assets/data/batches/realpaper_*.json
# 行为：跑 validate.py --cross-batch，0 冲突才放行。

set -e

# 看是不是有 realpaper batch 改动
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(assets/data/batches|question_bank)/realpaper_.*\.json$' || true)
if [ -z "$staged" ]; then
    exit 0  # 没动题库，跳
fi

echo "[pre-commit] 检测到 realpaper batch 改动，跑 cross-batch group_id 冲突检查..."
if ! python3 tools/realpaper/validate.py --cross-batch; then
    echo ""
    echo "❌ commit 被拦：group_id 跨 batch 冲突未解决。"
    echo "   修法：tools/realpaper/validate.py 显示了冲突的 group_id 和涉及的 batch。"
    echo "   群组 ID 必须以完整 batch source 为前缀（§9.3.3 V3.19.2）。"
    exit 1
fi
echo "[pre-commit] ✅ cross-batch 0 冲突"

# 只有 chinese batch 改动时跑 material-coverage 检查（V3.19.7）
chinese_staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(assets/data/batches|question_bank)/realpaper_g6_chinese_.*\.json$' || true)
if [ -n "$chinese_staged" ]; then
    echo "[pre-commit] 检测到 chinese batch 改动，跑 material-coverage 检查（V3.19.7）..."
    if ! python3 tools/realpaper/validate.py --material-coverage; then
        echo ""
        echo "❌ commit 被拦：组合题阅读理解子题原文材料覆盖率 < 30%（§⊥0a V3.19.7）。"
        echo "   修法：组合题子题 content 必须含 _raw_excerpt 的完整材料文字（≥30% 25-char n-gram 覆盖）。"
        echo "   禁用 \"（同上）\" / \"见上文\" / 简化 \"《XX》节选阅读\" 跳过材料正文。"
        exit 1
    fi
    echo "[pre-commit] ✅ material-coverage 通过"
fi

# realpaper batch 改动时也跑 worker-hint 检查（V3.19.14）
echo "[pre-commit] 跑 worker-hint 检查（V3.19.14）..."
if ! python3 tools/realpaper/validate.py --worker-hint; then
    echo ""
    echo "❌ commit 被拦：worker 加题型提示文字违纪（§1.5 不改题）。"
    echo "   修法：删除 \"N 空\" / \"N 个字母\" / \"按顺序填入\" / \"，。\" 等 worker 加的提示文字。"
    echo "   原题原文逐字保留，禁止脑补题型说明。"
    exit 1
fi
echo "[pre-commit] ✅ worker-hint 通过"

# common-prefix 检查（V3.19.17b）：组合题阅读子题需 _common_prefix_raw（chinese only）
if [ -n "$chinese_staged" ]; then
    echo "[pre-commit] 跑 common-prefix 检查（V3.19.17b）..."
    if ! python3 tools/realpaper/validate.py --common-prefix; then
        echo ""
        echo "❌ commit 被拦：阅读类组合题缺 _common_prefix_raw（R17）。"
        echo "   修法：组合题任一子题必须填 _common_prefix_raw（整组共同材料原文）。"
        exit 1
    fi
    echo "[pre-commit] ✅ common-prefix 通过"
fi

# group-kp 检查（V3.21 R31）：同 group_id 子题 KP 必须一致
echo "[pre-commit] 跑 group-kp 检查（V3.21 R31）..."
if ! python3 tools/realpaper/validate.py --group-kp; then
    echo ""
    echo "❌ commit 被拦：组合题子题 KP 异质（R31）。"
    echo "   修法：同 group_id 子题 knowledge_point 必须完全相同；按归约表选单 KP（见 SKILL.md R31）。"
    echo "   - 数学异质/跨章 → 综合练习 单段"
    echo "   - 语文：现代文→现代文阅读，文言文→文言文阅读，古诗→古诗词鉴赏，资料卡→材料阅读，字词类→词语理解"
    exit 1
fi
echo "[pre-commit] ✅ group-kp 通过"

# image-content-match 检查（V3.23 R33）：仅在 realpaper batch staged 时跑
echo "[pre-commit] 跑 image-content-match 检查（V3.23 R33）..."
if ! python3 tools/realpaper/validate.py --image-content-match; then
    echo ""
    echo "❌ commit 被拦：含 image_data 的题未 worker self-verify（R33）。"
    echo "   修法：worker 必 Read 图原文 + 比对题面线索后写 _image_verified=true 字段。"
    echo "   严禁 paragraph_image_map 推断完不 verify 直接绑——参 q48 圆柱图错绑前车之鉴。"
    exit 1
fi
echo "[pre-commit] ✅ image-content-match 通过"

# docx-sha1-real 检查（V3.23 R34）：仅在 realpaper batch staged 时跑
echo "[pre-commit] 跑 docx-sha1-real 检查（V3.23 R34）..."
if ! python3 tools/realpaper/validate.py --docx-sha1-real; then
    echo ""
    echo "❌ commit 被拦：_source_docx_sha1 / _source_docx_path 不真实（R34）。"
    echo "   修法：worker 入库前必 assert hashlib.sha1(open(path,'rb').read()).hexdigest()[:16] == _source_docx_sha1。"
    echo "   batch JSON 必含 _source_docx_path（绝对路径或 ~/...）+ _source_docx_sha1（16 字符）。"
    exit 1
fi
echo "[pre-commit] ✅ docx-sha1-real 通过"

# curriculum.json vs seed 一致性（V3.23）：仅在 seed 或 curriculum.json 改动时跑
cur_staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(lib/database/curriculum_seed\.dart|question_bank/curriculum\.json)$' || true)
if [ -n "$cur_staged" ]; then
    echo "[pre-commit] 跑 curriculum-consistency 检查（V3.23）..."
    if ! python3 tools/check_curriculum_consistency.py; then
        echo ""
        echo "❌ commit 被拦：curriculum.json 与 curriculum_seed.dart 不一致（V3.23 防漂移）。"
        echo "   修法：python3 tools/sync_curriculum_json.py && git add question_bank/curriculum.json"
        exit 1
    fi
    echo "[pre-commit] ✅ curriculum-consistency 通过"
fi

echo "[pre-commit] ✅ 全部检查放行（8 层防线）"
exit 0
