#!/usr/bin/env bash
# V3.19.2 pre-commit hook: 防 group_id 跨 batch 命名空间冲突
# 启用方式（新设备 clone 后跑一次）: git config core.hooksPath .githooks
#
# 触发条件：本次 commit 改动了 assets/data/batches/realpaper_*.json
# 行为：跑 validate.py --cross-batch，0 冲突才放行。

set -e

# 看是不是有 realpaper batch 改动
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(assets/data/batches|question_bank)/realpaper_.*\.json$' || true)
if [ -z "$staged" ]; then
    exit 0  # 没动题库，跳
fi

echo "[pre-commit] 检测到 realpaper batch 改动，跑 cross-batch group_id 冲突检查..."
if ! python3 tools/realpaper/validate.py --cross-batch; then
    echo ""
    echo "❌ commit 被拦：group_id 跨 batch 冲突未解决。"
    echo "   修法：tools/realpaper/validate.py 显示了冲突的 group_id 和涉及的 batch。"
    echo "   群组 ID 必须以完整 batch source 为前缀（§9.3.3 V3.19.2）。"
    exit 1
fi
echo "[pre-commit] ✅ cross-batch 0 冲突"

# 只有 chinese batch 改动时跑 material-coverage 检查（V3.19.7）
chinese_staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(assets/data/batches|question_bank)/realpaper_g6_chinese_.*\.json$' || true)
if [ -n "$chinese_staged" ]; then
    echo "[pre-commit] 检测到 chinese batch 改动，跑 material-coverage 检查（V3.19.7）..."
    if ! python3 tools/realpaper/validate.py --material-coverage; then
        echo ""
        echo "❌ commit 被拦：组合题阅读理解子题原文材料覆盖率 < 30%（§⊥0a V3.19.7）。"
        echo "   修法：组合题子题 content 必须含 _raw_excerpt 的完整材料文字（≥30% 25-char n-gram 覆盖）。"
        echo "   禁用 \"（同上）\" / \"见上文\" / 简化 \"《XX》节选阅读\" 跳过材料正文。"
        exit 1
    fi
    echo "[pre-commit] ✅ material-coverage 通过"
fi

# realpaper batch 改动时也跑 worker-hint 检查（V3.19.14）
echo "[pre-commit] 跑 worker-hint 检查（V3.19.14）..."
if ! python3 tools/realpaper/validate.py --worker-hint; then
    echo ""
    echo "❌ commit 被拦：worker 加题型提示文字违纪（§1.5 不改题）。"
    echo "   修法：删除 \"N 空\" / \"N 个字母\" / \"按顺序填入\" / \"，。\" 等 worker 加的提示文字。"
    echo "   原题原文逐字保留，禁止脑补题型说明。"
    exit 1
fi
echo "[pre-commit] ✅ worker-hint 通过"

echo "[pre-commit] ✅ 全部检查放行"
exit 0
